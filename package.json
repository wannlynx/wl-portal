{
  "name": "petroleum-dashboard",
  "private": true,
  "version": "3.0.0",
  "workspaces": [
    "apps/api",
    "apps/web",
    "apps/web-mui"
  ],
  "scripts": {
    "setup:local": "powershell -ExecutionPolicy Bypass -File scripts/setup-local.ps1",
    "dev": "npm-run-all --parallel dev:api dev:web-mui",
    "dev:api": "npm --workspace apps/api run dev",
    "dev:web": "npm --workspace apps/web-mui run dev",
    "dev:web-mui": "npm --workspace apps/web-mui run dev",
    "dev:web-legacy": "npm --workspace apps/web run dev -- --port 5174",
    "seed": "npm --workspace apps/api run seed",
    "build": "npm-run-all build:api build:web",
    "build:api": "npm --workspace apps/api run build",
    "build:web": "npm --workspace apps/web-mui run build",
    "build:web-mui": "npm --workspace apps/web-mui run build",
    "build:web-legacy": "npm --workspace apps/web run build"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  }
}
